@page
@model Members.Pages.DonateModel

@{
    var name = Model.LegalName;
    var oib = Model.Oib;
    var amount = Model.Amount;
    var email = Model.Email;
    var note = Model.Note;

    bool isGuest = Model.IsGuest;
}

@{
    Html.RenderPartial("_Header", T["Podaci za uplatu"].Value);
}
<script asp-name="ugptheme-jQuery"></script>
<script asp-name="ugptheme-barcode"></script>

<script type="text/javascript">
      var name="@name";
      var oib="@oib";
      var amount="@amount";
      var email="@email";
      var note = "@note";
      var isGuest = "@isGuest";

      // Decode HTML entities (e.g., &#x17E; to ž)
      function decodeHtmlEntities(text) {
          var textArea = document.createElement('textarea');
          textArea.innerHTML = text;
          return textArea.value;
      }

      // Decode server-side encoded values
      name = decodeHtmlEntities(name);
      oib = decodeHtmlEntities(oib);

      function drawBarcode(customAmount, customName, customOib) {
          // Get current values from inputs or use parameters/defaults
          var currentAmount = customAmount || document.getElementById('amountSelector')?.value || amount;
          var currentName = customName || document.getElementById('nameInput')?.value || name;
          var currentOib = customOib || document.getElementById('oibInput')?.value || oib;

          const data = {
              header: 'HRVHUB30',
              currency: 'EUR',
              price: currentAmount + '.00' || '',
              name: currentName || '',
              email: email || '',
              cityAndPostalCode: '',
              recepient: 'GLAS PODUZETNIKA',
              recepientAddress: 'Ulica Republike Austrije 33',
              recepientCityAndPostalCode: '10000 Zagreb',
              IBAN: 'HR2324020061100970954',
              callNumber: currentOib?'HR00':'HR99',
              OIB: currentOib || '',
              code: 'COST',
              description: note || 'Donacija'
          }
          const code = Object.values(data).reduce((prev, curr) => `${prev}\n${curr}`, '')

              drawBarcodeToDiv("barcodeDiv",code.substr(1))
              var amountHelper = document.getElementById('amountHelper');
              if (amountHelper) {
                  amountHelper.value = currentAmount;
              }
          
      }



      window.onload = function () {
          // Amount input handler
          var amountSelector = document.getElementById('amountSelector');
          if (amountSelector) {
              amountSelector.value = amount;
              amountSelector.addEventListener('input', (event) => {
                  var amountHelper = document.getElementById('amountHelper');
                  if (amountHelper) {
                      amountHelper.value = event.target.value;
                  }
                  if (event.target.value) {
                      drawBarcode();
                  }
              });
          }

          // OIB input handler
          var oibInput = document.getElementById('oibInput');
          if (oibInput) {
              oibInput.value = oib;
              oibInput.addEventListener('input', () => {
                  drawBarcode();
              });
          }
      }


    $(function () {
      drawBarcode();
    });
</script>

<div class="row">
    <div class="container">
        <span>IBAN: HR2324020061100970954</span><br />
        <span>GLAS PODUZETNIKA</span><br />
        <span>Ulica Republike Austrije 33, Zagreb</span><br />
        <span>model „HR00“ i poziv na broj „00000-OIB UPLATITELJA“.</span><br />
        <br />

        Ili priredite i skenirajte barkod za uplatu:


    </p>

    <div class="accordion accordion-flush border" id="accordionFlushExample">
        <div class="accordion-item">
            <h2 class="accordion-header" id="flush-headingTwo">
                <button class="accordion-button h2" type="button" data-bs-toggle="collapse" data-bs-target="#flush-collapseTwo" aria-expanded="false" aria-controls="flush-collapseTwo">
                    Mobilno plaćanje
                </button>
            </h2>
            <div id="flush-collapseTwo" class="accordion-collapse show" aria-labelledby="flush-headingTwo" data-bs-parent="#accordionFlushExample">
                <div class="accordion-body">
                    <form method="post" id="personSelector">
                        @if (Model.PersonList != null && Model.PersonList.Count > 0)
                        {
                            <div class="input-group mb-3">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">Osoba/Tvrtka</span>
                                </div>
                                <select class="form-select" asp-for="PersonId" onchange="this.form.submit();">
                                    @foreach (var item in Model.PersonList)
                                    {
                                        <option value="@item.ContentItemId">@item.Content.PersonPart.Name.Text</option>
                                    }
                                </select>
                            </div>
                        }

                        <div class="input-group mb-3">
                            <div class="input-group-prepend">
                                <span class="input-group-text">OIB donatora</span>
                            </div>
                            <input type="text" class="form-control" id="oibInput" placeholder="Unesite OIB" maxlength="11" pattern="[0-9]{11}" aria-label="OIB" />
                        </div>

                        <div class="input-group mb-3">
                            <div class="input-group-prepend">
                                <span class="input-group-text">Iznos</span>
                            </div>
                            <input type="number" class="form-control" id="amountSelector" min="1" step="1" placeholder="Unesite iznos" aria-label="Amount" />
                            <div class="input-group-append">
                                <span class="input-group-text">EUR</span>
                            </div>
                        </div>
                        <input type="text" asp-for="Amount" id="amountHelper" style="display: none;" />
                    </form>

                    <div id="barcodeDiv" class="list-group list-group-flush fs-6">
                    </div>

                    <div class="text-center my-3">
                        <button type="button" class="btn btn-primary" onclick="downloadBarcode('barcodeDiv',document.getElementById('amountSelector').value)">
                            <i class="bi bi-download"></i> Preuzmi barkod
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</div>
