@model OrchardCore.Users.ViewModels.RegisterViewModel

@*
    Overrides OrchardCore.Users' template: the username is always the email
    address (see Members.Users.EmailRegisterUserFormDisplayDriver), so there
    is no separate username field.
*@

<div class="mb-3">
    <label asp-for="Email" class="form-label">@T["Email address"]</label>
    <input asp-for="Email" class="form-control" autofocus />
    <span asp-validation-for="Email" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="Password" class="form-label">@T["Password"]</label>
    <input asp-for="Password" class="form-control" autocomplete="new-password" />
    <span asp-validation-for="Password" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="ConfirmPassword" class="form-label">@T["Confirm password"]</label>
    <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
</div>
